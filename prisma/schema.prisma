generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ── NextAuth ──────────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("viewer")
  passwordHash  String?   // for credential-based admin login
  accounts      Account[]
  sessions      Session[]
}

// ── Domain ────────────────────────────────────────────────
model Player {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  phone     String?
  createdAt DateTime @default(now())

  teamsAsPlayer1 Team[] @relation("TeamPlayer1")
  teamsAsPlayer2 Team[] @relation("TeamPlayer2")
}

// Team = singiel (1 gracz) lub debel (2 graczy)
model Team {
  id           String  @id @default(cuid())
  tournamentId String
  name         String? // opcjonalna własna nazwa dla debla
  player1Id    String
  player2Id    String? // null → singiel

  tournament     Tournament     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player1        Player         @relation("TeamPlayer1", fields: [player1Id], references: [id])
  player2        Player?        @relation("TeamPlayer2", fields: [player2Id], references: [id])
  matchesAsTeam1 Match[]        @relation("MatchTeam1")
  matchesAsTeam2 Match[]        @relation("MatchTeam2")
  rankingEntries RankingEntry[]
}

model Tournament {
  id        String   @id @default(cuid())
  name      String
  date      DateTime
  location  String?
  notes     String?
  // Format gry
  format    String   @default("singles")      // "singles" | "doubles"
  // System rozgrywek
  system    String   @default("round_robin")  // "round_robin" | "americano" | "groups_playoff" | "elimination"
  groups      Int      @default(1)              // liczba grup (dla groups_playoff)
  courts      Int      @default(1)              // liczba kortów (dla americano)
  pointsToWin Int      @default(21)             // punkty do wygrania meczu (dla americano)
  completed   Boolean  @default(false)          // turniej zakończony (bez lub po Final Round)
  createdAt   DateTime @default(now())

  matches        Match[]
  rankingEntries RankingEntry[]
  teams          Team[]
}

model Match {
  id           String   @id @default(cuid())
  tournamentId String
  team1Id      String
  team2Id      String
  round        Int?     // numer rundy (1, 2, 3…)
  court        Int?     // numer kortu (dla americano)
  group        String?  // nazwa grupy (A, B, C…) dla groups_playoff
  status       String   @default("pending") // "pending" | "completed"
  createdAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team1      Team       @relation("MatchTeam1", fields: [team1Id], references: [id])
  team2      Team       @relation("MatchTeam2", fields: [team2Id], references: [id])
  sets       Set[]
}

model Set {
  id           String @id @default(cuid())
  matchId      String
  setNumber    Int
  team1Score   Int
  team2Score   Int

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model RankingEntry {
  id           String  @id @default(cuid())
  tournamentId String
  teamId       String
  group        String? // dla groups_playoff
  points       Int     @default(0)
  wins         Int     @default(0)
  losses       Int     @default(0)
  gamesWon     Int     @default(0)  // sety/gemy wygranych (Americano liczy gemy)
  gamesLost    Int     @default(0)

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team       Team       @relation(fields: [teamId], references: [id])

  @@unique([tournamentId, teamId])
}
